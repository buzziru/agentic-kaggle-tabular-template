{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python scripts/hooks/guard_frozen.py", "timeout": 10 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python scripts/hooks/guard_bash.py", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python scripts/hooks/lint_notebook.py", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python scripts/hooks/stop_reminder.py" }
        ]
      }
    ]
  }
}
